<Window x:Class="XylarBedrock.Pages.General.StoreAutoUpdatePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="500"
        Height="292"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="MinecraftPromptButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="144"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontFamily" Value="/XylarBedrock;component/Resources/fonts/#Minecraft Ten"/>
            <Setter Property="BorderBrush" Value="#171717"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid x:Name="ButtonRoot"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2"/>
                            <Border Height="5"
                                    VerticalAlignment="Bottom"
                                    Margin="2,0,2,2"
                                    Background="#3D000000"
                                    CornerRadius="0,0,1,1"/>
                            <TextBlock Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,-3,0,0"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.025" Duration="0:0:0.10"/>
                                        <DoubleAnimation Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.025" Duration="0:0:0.10"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.14"/>
                                        <DoubleAnimation Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.14"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#A3000000">
        <Border x:Name="DialogCard"
                Width="456"
                Padding="0"
                Background="#EE252525"
                BorderBrush="#FF5C5C5C"
                BorderThickness="2"
                CornerRadius="4"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="DialogScale" ScaleX="0.94" ScaleY="0.94"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="28"
                                  ShadowDepth="8"
                                  Direction="270"
                                  Color="#000000"
                                  Opacity="0.65"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="46"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="72"/>
                </Grid.RowDefinitions>

                <Border Background="#D8D8D8"
                        BorderBrush="#8A8A8A"
                        BorderThickness="0,0,0,2"
                        CornerRadius="2,2,0,0">
                    <TextBlock Text="MINECRAFT AUTO-UPDATES"
                               Margin="18,0,0,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Foreground="#262626"
                               FontFamily="/XylarBedrock;component/Resources/fonts/#Minecraft Ten"
                               FontSize="21"
                               TextOptions.TextFormattingMode="Display"/>
                </Border>

                <Grid Grid.Row="1" Margin="22,18,22,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="76"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="60"
                            Height="60"
                            Padding="8"
                            Background="#151515"
                            BorderBrush="#3F3F3F"
                            BorderThickness="2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <Image Source="/XylarBedrock;component/resources/images/icons/xylarbedrock.png"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="keep older Minecraft versions from auto-updating?"
                                   Foreground="White"
                                   FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="Recommended when using older Minecraft builds."
                                   Margin="0,7,0,0"
                                   Foreground="#FFFFD83D"
                                   FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                                   FontSize="12.5"
                                   TextWrapping="Wrap"/>
                        <TextBlock Margin="0,10,0,0"
                                   Foreground="#DADADA"
                                   FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                                   FontSize="12"
                                   LineHeight="17"
                                   TextWrapping="Wrap"
                                   MaxHeight="70"
                                   Text="XylarBedrock will not disable Windows Update or security updates. It only opens Microsoft Store settings so you can turn off automatic app updates yourself."/>
                        <TextBlock Text="You can choose Later and do it manually anytime."
                                   Margin="0,10,0,0"
                                   Foreground="#8FFFFFFF"
                                   FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                                   FontSize="10.5"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2"
                        Background="#DD1A1A1A"
                        BorderBrush="#3D3D3D"
                        BorderThickness="0,2,0,0"
                        CornerRadius="0,0,2,2">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,18,0">
                        <Button Content="LATER"
                                Style="{StaticResource MinecraftPromptButton}"
                                Background="#555555"
                                BorderBrush="#1E1E1E"
                                Click="LaterButton_Click"/>
                        <Button Content="YES"
                                Margin="12,0,0,0"
                                Style="{StaticResource MinecraftPromptButton}"
                                Background="#2F9E44"
                                BorderBrush="#1D4F23"
                                Click="YesButton_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
